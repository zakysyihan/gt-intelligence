# GT Intelligence — Environment Variables
# Copy to .env and fill in values. NEVER commit .env.

# LLM API (SumoPod AI — DeepSeek V4 Flash)
OPENAI_API_KEY=your-sumopod-api-key
OPENAI_BASE_URL=https://ai.sumopod.com/v1

# Model (configurable — switch to gpt-4o-mini or o3-mini if needed)
MODEL_NAME=deepseek/deepseek-chat

# App
HOST=0.0.0.0
PORT=8000
